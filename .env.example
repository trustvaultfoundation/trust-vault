# TrustVault (trustvault.foundation) environment variables — TEMPLATE
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in your own values.
# NEVER commit real secrets. `.env*` is already gitignored.
#
# The core app runs WITHOUT any of these. Vars WITHOUT the NEXT_PUBLIC_ prefix
# are SERVER-ONLY and never reach the browser.
#
# NOTE: the ar.io deploy and its wallet secrets live in the sibling
# ../trust-vault-ar-io project, not here.
# ---------------------------------------------------------------------------

# --- Public (client) flags -------------------------------------------------
# These ARE bundled into the browser build (NEXT_PUBLIC_). Put no secrets here.

# Enable the encrypted durable state-sync (Arweave snapshots). "1" to enable.
NEXT_PUBLIC_STATE_SYNC=
