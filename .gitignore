# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
package-lock.json
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real secrets (wallet JWKs, ArNS config)
.env*
# ...but DO ship the redacted template
!.env.example

# secret keys / wallets (defense in depth — never commit these)
*.pem
*.jwk
wallet.json
ao-wallet.json

# AI assistant / editor instruction files (kept private)
CLAUDE.md
AGENTS.md
.claude/
.cursor/
.aider*
.github/copilot-instructions.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# static export + deploy
/out
/wallet.json
/ao-wallet.json
/src/.api-static-tmp

# cloudflare
.wrangler