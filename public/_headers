# Cloudflare Pages security headers.
# This file is copied verbatim from public/ into ./out at build time and read by
# Cloudflare Pages. Format docs: https://developers.cloudflare.com/pages/configuration/headers/
#
# Notes for TrustVault (fully static, client-side Arweave app):
#   - script-src stays locked to our own origin (no third-party scripts) but needs
#     'unsafe-inline' because a static Next.js export inlines its hydration scripts
#     (no server = no per-request nonce) and 'wasm-unsafe-eval' for the crypto/bundler
#     WASM used by arbundles / @irys. This still blocks injected external scripts (XSS).
#   - connect-src / img-src allow https: because the app talks to many *dynamic* Arweave
#     gateways and loads on-chain images/tiles from arbitrary hosts; enumerating them
#     would break decentralised fetches. This is the intended trade-off for a permaweb app.
#   - The Wander wallet is a browser extension (postMessage / injected window.arweaveWallet),
#     so it needs no CSP allowance here.

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https: wss:; media-src 'self' blob:; worker-src 'self' blob:; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Long-cache the immutable, content-hashed build assets.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
